.tab-bar {
    position: fixed;
    z-index: 999999;
    bottom: 0;
    left: 0;
    right: 0;
    display: flex;
    background: white;
    filter: drop-shadow(0px -2px 10px rgba(0, 0, 0, 0.06));
    padding-bottom: env(safe-area-inset-bottom);
}

.tab-bar-item {
    flex: 1;
    display: flex;
    justify-content: center;
    align-items: center;
    flex-direction: column;
    position: relative;
}

.tab-bar-item-center {
    width: 132rpx;
    height: 132rpx;
    position: relative;
}

.tab-bar-item-image {
    width: 48rpx;
    height: 48rpx;
    position: relative;
}

.tab-bar-item-view {
    font-size: 20rpx;
    line-height: 36rpx;
}

.tab-bar-public {
    width: 100%;
    height: 55px;
    border-radius: 50%;
    /* background-color: #fff; */
    position: absolute;
    /* top: -12rpx; */
    display: flex;
    align-items: center;
    justify-content: center;
}

.tab-bar-public-background {
    width: 56rpx;
    height: 56rpx;
    border-radius: 50%;
    box-shadow: 0px 4px 12px rgba(51, 51, 51, 0.12);
    /* background: linear-gradient(84.52deg,#7289ff 28.29%,#6c8ff1 100%); */
    background: #333;
    display: flex;
    align-items: center;
    justify-content: center;
}

.tab-bar-public-icon {
    width: 28rpx;
    height: 28rpx;
}

.tab-bar-badge {
    position: absolute;
    top: 0;
    right: 0;
    width: 18rpx;
    height: 18rpx;
    border-radius: 50%;
    background: #FF5F5C;
}