APP_NAME=InfiniLink
HTTP_ADDR=:8080
PUBLIC_BASE_URL=http://127.0.0.1
DATABASE_URL=postgres://postgres:postgres@postgres:5432/infinilink?sslmode=disable
DB_MAX_CONNS=48
DB_MIN_CONNS=8
DB_MAX_CONN_LIFETIME=1h
DB_MAX_CONN_IDLE_TIME=15m
DB_HEALTH_CHECK_PERIOD=1m

REDIS_ADDR=redis:6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=64

JWT_SECRET=change-me-in-production
TOKEN_TTL=4320h
UPLOAD_DIR=./storage/uploads
ASSETS_DIR=./static
MAX_UPLOAD_BYTES=26214400
MEMBERSHIP_PRICE=99
AUTO_MIGRATE=true
ENABLE_SEED_CONTENT=true

CACHE_TTL=5m
USER_CACHE_TTL=90s
ORDER_LOCK_TTL=30s

HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=30s
HTTP_IDLE_TIMEOUT=60s
SHUTDOWN_TIMEOUT=15s
MAX_HEADER_BYTES=1048576

WECHAT_APP_ID=
WECHAT_APP_SECRET=
WXPAY_MCH_ID=
WXPAY_API_V3_KEY=
WXPAY_SERIAL_NO=
WXPAY_PRIVATE_KEY=
WXPAY_NOTIFY_URL=http://127.0.0.1/payments/wechat/notify

IF_PAY_BASE_URL=
IF_PAY_CREATE_PATH=/api/wallet/payment
IF_PAY_API_SECRET=
IF_PAY_TIMEOUT=8s
IF_PAY_NOTIFY_SECRET=

DEFAULT_PAY_METHOD=wechat
PAYMENT_MOCK_PAID=false
