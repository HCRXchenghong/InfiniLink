APP_NAME=InfiniLink
HTTP_ADDR=:8080
PUBLIC_BASE_URL=https://your-domain.com
DATABASE_URL=postgres://postgres:replace-me@postgres:5432/infinilink?sslmode=disable
DB_MAX_CONNS=120
DB_MIN_CONNS=24
DB_MAX_CONN_LIFETIME=1h
DB_MAX_CONN_IDLE_TIME=15m
DB_HEALTH_CHECK_PERIOD=1m

POSTGRES_DB=infinilink
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-me

REDIS_ADDR=redis:6379
REDIS_USERNAME=
REDIS_PASSWORD=replace-me
REDIS_DB=0
REDIS_POOL_SIZE=256
REDIS_MIN_IDLE_CONNS=32
REDIS_MAX_RETRIES=2
REDIS_DIAL_TIMEOUT=2s
REDIS_READ_TIMEOUT=1s
REDIS_WRITE_TIMEOUT=1s
REDIS_POOL_TIMEOUT=2s

JWT_SECRET=replace-with-long-random-secret
TOKEN_TTL=4320h
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-strong-password
ADMIN_TOKEN_TTL=24h
UPLOAD_DIR=./storage/uploads
ASSETS_DIR=./static
MAX_UPLOAD_BYTES=26214400
MEMBERSHIP_PRICE=99
AUTO_MIGRATE=true
ENABLE_SEED_CONTENT=false

CACHE_TTL=10m
USER_CACHE_TTL=2m
ORDER_LOCK_TTL=30s

HTTP_READ_TIMEOUT=10s
HTTP_READ_HEADER_TIMEOUT=5s
HTTP_WRITE_TIMEOUT=45s
HTTP_IDLE_TIMEOUT=90s
SHUTDOWN_TIMEOUT=20s
MAX_HEADER_BYTES=1048576
INFLIGHT_LIMIT=12000
REALTIME_ADDR=:8090
REALTIME_PRESENCE_TTL=90s
REALTIME_HEARTBEAT_INTERVAL=25s
REALTIME_SHUTDOWN_TIMEOUT=20s

WECHAT_APP_ID=wx_replace_me
WECHAT_APP_SECRET=replace-me
WXPAY_MCH_ID=replace-me
WXPAY_API_V3_KEY=replace-me
WXPAY_SERIAL_NO=replace-me
WXPAY_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nreplace-me\n-----END PRIVATE KEY-----
WXPAY_NOTIFY_URL=https://your-domain.com/payments/wechat/notify

IF_PAY_BASE_URL=https://pay-center.your-domain.com
IF_PAY_CREATE_PATH=/api/ifpay/v1/payments
IF_PAY_OAUTH_AUTHORIZE_PATH=/api/ifpay/oauth/authorize
IF_PAY_OAUTH_TOKEN_PATH=/api/ifpay/oauth/token
IF_PAY_OAUTH_USERINFO_PATH=/api/ifpay/oauth/userinfo
IF_PAY_APP_ID=partner_app_replace_me
IF_PAY_CLIENT_ID=replace-me
IF_PAY_CLIENT_SECRET=replace-me
IF_PAY_SIGNING_SERIAL=replace-me
IF_PAY_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nreplace-me\n-----END PRIVATE KEY-----
IF_PAY_WEBHOOK_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nreplace-me\n-----END PUBLIC KEY-----
IF_PAY_WEBHOOK_SERIAL=ifpay-platform-default
IF_PAY_SCOPES=openid wallet:read wallet:write payments:read payments:write
IF_PAY_API_SECRET=
IF_PAY_TIMEOUT=8s
IF_PAY_NOTIFY_SECRET=

DEFAULT_PAY_METHOD=ifpay
PAYMENT_MOCK_PAID=false
