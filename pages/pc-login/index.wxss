.contain {
  width: 100%;
  height: 100%;
  background: #000;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.contain .logo-box {
  top: 16%;
  position: fixed;
  z-index: 99;
  font-weight: bold;
  color: #333;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.contain .logo-box .img {
  width: 100rpx;
  height: 100rpx;
}

.contain .logo-box .logosub {
  margin-top: 30rpx;
  font-size: 32rpx;
}

.login_bg {
  width: 100%;
  position: fixed;
  z-index: 100;
  display: flex;
  align-items: center;
  flex-direction: column;
  justify-content: center;
  bottom: 100px;
  padding-bottom: env(safe-area-inset-bottom);
}

.btn {
  width: 300rpx;
  height: 90rpx;
  margin-bottom: 20px;
  background: #333333;
  border-radius: 20rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn2 {
  color: #949494;
  font-size: 32rpx;
  font-weight: 500;
}