@import "/pages/template/circle.wxss";
@import "/styles/level.wxss";

.user-background {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
}

.user-background .bac-image {
  width: 100%;
  height: 650rpx;
  animation: fadeIn 1s ease;
}

.user-background .gradient {
  position: absolute;
  height: 650rpx;
  width: 100%;
  top: 0;
  bottom: 0;
  background-image: linear-gradient(to bottom, transparent, rgba(0, 0, 0, 0.6));
}

.own-header {
  position: absolute;
  left: 30rpx;
  bottom: 60rpx;
  display: flex;
  justify-content: center;
  flex-flow: column nowrap;
}

.header-top {
  width: 720rpx;
  height: 280rpx;
  display: flex;
  flex-direction: column;
}

.own-header-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 120rpx;
  border: 5rpx solid #fff;
}

.header-middle {
  margin-top: 38rpx;
  color: #fff;
  font-size: 34rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
}

.name-text {
  max-width: 550rpx;
  text-overflow: ellipsis;
  overflow: hidden;
  white-space: nowrap;
}

.header-labels {
  width: 32rpx;
  height: 32rpx;
  margin-left: 12rpx;
}

.membership-badge {
  min-width: 70rpx;
  height: 34rpx;
  padding: 0 12rpx;
  margin-left: 12rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  line-height: 34rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.membership-badge-pro {
  background: rgba(255, 255, 255, 0.18);
  border: 1px solid rgba(255, 255, 255, 0.4);
  color: #fff4bf;
}

.membership-badge-max {
  background: #111827;
  border: 1px solid rgba(255, 255, 255, 0.28);
  color: #ffffff;
}

.level-badge {
  min-width: 72rpx;
  height: 34rpx;
  padding: 0 12rpx;
  margin-left: 12rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.12);
  border: 1px solid rgba(255, 255, 255, 0.32);
  color: #ffffff;
  font-size: 18rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.header-abstract {
  margin-top: 10rpx;
  font-size: 26rpx;
  font-weight: 400;
  color: #fff;
  width: 600rpx;
  text-overflow: ellipsis;
  overflow: hidden;
  white-space: nowrap;
}

.header-bottom {
  width: 100%;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.header-zuo {
  width: 350rpx;
  height: 100rpx;
  display: flex;
  justify-content: flex-start;
}

.header-bottom-li {
  -webkit-box-flex: 1;
  flex: 1;
}

.own-header-num {
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 50rpx;
}

.own-header-text {
  color: #fff;
  font-size: 20rpx;
}

.header-right-box {
  position: absolute;
  bottom: 30rpx;
  right: 30rpx;
  display: flex;
  align-items: center;
}

.header-box {
  height: 50rpx;
  border-radius: 500rpx;
  background-color: rgba(0, 0, 0, 0.3);
  border: 1px solid #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.header-right {
  width: 160rpx;
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
}

.header-setup {
  width: 80rpx;
  margin-left: 24rpx;
}

.tab-list {
  position: absolute;
  top: 620rpx;
  left: 0;
  width: 100%;
  background: #fff;
  border-radius: 30rpx 30rpx 0 0;
  padding-bottom: env(safe-area-inset-bottom);
}

.home-recommend {
  padding: 30rpx 0;
  margin: 0 30rpx;
  font-size: 22rpx;
  font-weight: bold;
  color: #333;
  border-bottom: 1px solid #f5f5f5;
}

.home-recommend text {
  margin-right: 6rpx;
  font-size: 42rpx;
}

.vip-img {
  width: 500rpx;
  height: 500rpx;
}

.like-box {
  width: 500rpx;
  height: 380rpx;
  background: #fff;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  flex-direction: column;
  justify-content: flex-end;
  position: relative;
}

.like-box image {
  position: absolute;
  top: -120rpx;
  width: 400rpx;
  height: 400rpx;
  animation: fadeIn 0.6s ease;
}

.like-box view {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  height: 90rpx;
}

.like-box text {
  font-size: 26rpx;
  color: #949494;
  height: 45rpx;
  max-width: 450rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
