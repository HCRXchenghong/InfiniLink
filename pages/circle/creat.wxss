.notice-bar {
  background: #ff6d6d !important;
  color: #FFFFFF !important;
  font-size: 26rpx !important;
}

.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
}

.content-container {
  width: 690rpx;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  align-items: center;
  box-sizing: border-box;
}

.img-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
}

.logo-container {
  position: relative;
  height: 200rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  box-sizing: border-box;
  background: #f5f5f5;
  border-radius: 8rpx;
  margin-top: 40rpx;
  margin-bottom: 40rpx;
}

.logo-add {
  width: 64rpx;
  height: 64rpx;
}

.w200 {
  width: 200rpx;
}

.w460 {
  width: 460rpx;
}

.logo-image {
  height: 200rpx;
  border-radius: 8rpx;
  animation: fadeIn 1s ease;
}

.img-text {
  font-size: 24rpx;
  color: #949494;
}

.logo-camera {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 500rpx;
  background: rgba(0, 0, 0, 0.3);
}

.item {
  position: relative;
  width: 100%;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  align-items: flex-start;
  box-sizing: border-box;
  padding-top: 34rpx;
  padding-right: 32rpx;
  border-bottom: 1px solid #f5f5f5;
}

.item-title-left {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: flex-start;
  box-sizing: border-box;
}

.item-title {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.item-title-tip {
  font-size: 24rpx;
  color: #949494;
  margin-top: 12rpx;
}

.item-input {
  width: 100%;
  height: 94rpx;
  line-height: 94rpx;
  font-size: 32rpx;
  color: #333333;
}

.item-input-h {
  width: 400rpx;
  height: 112rpx;
  line-height: 112rpx;
  font-size: 32rpx;
  color: #333333;
  text-align: right;
}

.item-h-tip {
  width: 100%;
  height: 72rpx;
  line-height: 24rpx;
  font-size: 24rpx;
  color: #949494;
  box-sizing: border-box;
  padding-top: 20rpx;
}

.item-tip {
  position: absolute;
  top: 36rpx;
  right: 32rpx;
  font-size: 24rpx;
  color: #AAAAAA;
}

.item-area {
  width: 100%;
  height: 250rpx;
  font-size: 32rpx;
  color: #333333;
  box-sizing: border-box;
  padding: 32rpx 0;
}

.item-h {
  width: 100%;
  height: 112rpx;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  box-sizing: border-box;
  padding-right: 32rpx;
  border-bottom: 1px solid #f5f5f5;
}

.item-h-high {
  position: relative;
  height: 144rpx;
}

.item-value {
  position: absolute;
  right: 64rpx;
  font-size: 28rpx;
  color: #AAAAAA;
}

.item-arrow-icon {
  position: absolute;
  right: 32rpx;
  width: 24rpx;
  height: 24rpx;
}

.item-right-icon {
  position: absolute;
  right: 64rpx;
  width: 32rpx;
  height: 32rpx;
}

.bottom-tip-text {
  width: 100%;
  font-size: 24rpx;
  color: #949494;
  padding-right: 32rpx;
  box-sizing: border-box;
  margin-top: 32rpx;
}

.bottom-box {
  position: fixed;
  bottom: 0;
  left: 0;
  z-index: 9;
  width: 100%;
  padding-bottom: env(safe-area-inset-bottom);
}

.bottom {
  width: 100%;
  height: 120rpx;
  display: flex;
  flex-direction: row;
  justify-content: flex-start;
  align-items: center;
  box-sizing: border-box;
  padding: 0 32rpx;
  background: #FFFFFF;
  box-shadow: 0px -1px 4px 0px rgba(197, 202, 213, 0.25);
}

.bottom-radio {
  width: 34rpx;
  height: 34rpx;
  box-sizing: border-box;
}

.bottom-radio-text {
  font-size: 24rpx;
  color: #949494;
  margin-left: 8rpx;
}

.bottom-button {
  position: absolute;
  right: 32rpx;
  width: 176rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 28rpx;
  color: #FFFFFF;
  background: #333333;
  border-radius: 8rpx;
  text-align: center;
}

.picker {
  color: #333;
  font-size: 28rpx;
  display: flex;
  align-items: center;
}

.arrow {
  margin-left: 10rpx;
  width: 10rpx;
  height: 10rpx;
  border-top: 4rpx solid #333;
  border-right: 4rpx solid #333;
  transform: rotate(45deg);
}