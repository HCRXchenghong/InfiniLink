@import "/pages/template/circle.wxss";

.pd-btm {
  padding-bottom: 200rpx;
}

.container {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  display: flex;
  flex-direction: column;
  background: #fff;
}

.banner_image {
  width: 100%;
  height: 330rpx;
  animation: fadeIn 0.5s ease;
}

.banner_image_mask {
  width: 100%;
  height: 330rpx;
  position: absolute;
  z-index: 9;
  top: 0;
  left: 0;
  background: rgba(0, 0, 0, 0.3);
  animation: fadeIn 1s ease;
}

.dynamic {
  width: 100%;
  display: flex;
  flex-direction: column;
  background: #fff;
  border-radius: 30rpx 30rpx 0 0;
  margin-top: -30rpx;
  position: relative;
  z-index: 99;
}

.dynamic_top {
  width: 690rpx;
  height: 140rpx;
  margin: -70rpx auto 0;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}

.dynamic_top image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 500rpx;
  border: 2px solid #fff;
  background: #f5f5f5;
  animation: fadeIn 1s ease;
}

.banner_container_bottom {
  width: 520rpx;
  height: 54rpx;
  display: flex;
  justify-content: space-between;
  flex-direction: row;
}

.banner_container_bottom_option {
  color: #333;
  display: flex;
  align-items: center;
  font-size: 24rpx;
  font-weight: 400;
}

.banner_container_bottom_s {
  width: 1px;
  height: 18rpx;
  background: #333;
  margin: 0 20rpx;
}

.banner_container_bottom_option_join {
  padding-left: 40rpx;
}

.banner_container_bottom_right {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #333333;
  color: #fff;
  width: 134rpx;
  height: 54rpx;
  font-size: 24rpx;
  border-radius: 8rpx;
}

.yg {
  background: #f5f5f5 !important;
  color: #333 !important;
}

.banner_container {
  width: 690rpx;
  display: flex;
  justify-content: flex-start;
  flex-direction: column;
  padding: 30rpx 0;
  margin: 0 auto;
  border-bottom: 1px solid #f5f5f5;
}

.banner_container_topic {
  width: 690rpx;
  height: 50rpx;
  font-size: 38rpx;
  font-weight: 900;
  text-overflow: ellipsis;
  overflow: hidden;
  white-space: nowrap;
  color: #000;
}

.dynamic_Introducer-content {
  color: #333;
  line-height: 38rpx;
  font-size: 26rpx;
  text-indent: 80rpx;
  padding-top: 15rpx;
  display: -webkit-box;
  overflow: hidden;
  text-overflow: ellipsis;
  word-wrap: break-word;
  white-space: normal !important;
  -webkit-box-orient: vertical;
  animation: fadeIn 1s ease;
}

.icon-class-box {
  position: absolute;
  margin-top: 65rpx;
  right: 30rpx;
  width: 40rpx;
  height: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.l-icon-class {
  font-weight: bold !important;
  color: #333 !important;
}

.dynamic_Introducer-jianjie {
  position: absolute;
  margin-top: 65rpx;
  width: 64rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1px solid #f5f5f5;
  font-size: 20rpx;
  color: #333;
  border-radius: 8rpx;
}

.circle-user {
  display: flex;
  flex-direction: column;
  padding-top: 20rpx;
  border-bottom: 1px solid #f5f5f5;
}

.circle-user .circle-user-title {
  color: #333333;
  font-size: 28rpx;
  font-weight: bold;
  padding-bottom: 20rpx;
  margin-left: 30rpx;
}

.circle-user .user-list {
  display: flex;
  height: 160rpx;
}

.circle-user .user-box {
  display: flex;
  flex-direction: column;
  margin-left: 40rpx;
  width: 88rpx;
  height: 135rpx;
  position: relative;
}

.user-box:last-child {
  padding-right: 40rpx;
}

.circle-user .user-box image {
  width: 88rpx;
  height: 88rpx;
  border-radius: 88rpx;
  background: #f5f5f5;
  animation: fadeIn 1s ease;
}

.circle-user .user-box text {
  position: absolute;
  bottom: 0;
  text-align: center;
  width: 88rpx;
  line-height: 35rpx;
  font-size: 22rpx;
  color: #949494;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.circle-user .user-box .qz {
  position: absolute;
  bottom: 0;
  left: 18rpx;
  width: 54rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  font-weight: bold;
  color: #fff;
  background: #333;
  border-radius: 8rpx;
}

.nav {
  width: 100%;
  height: 90rpx;
  display: flex;
  font-size: 32rpx;
  line-height: 90rpx;
  background: #FFF;
}

.header-sticky-class {
  box-sizing: border-box !important;
  z-index: 99 !important;
}

.tag-box {
  padding: 0 30rpx;
}

.taga-item {
  font-size: 32rpx;
  color: #949494;
  font-weight: 450;
}

.tag-box .active {
  color: #333333 !important;
  font-weight: bold !important;
  position: relative;
}

.tag-box .active:after {
  content: "";
  display: block;
  width: 16rpx;
  height: 6rpx;
  background: #333333;
  border-radius: 6rpx;
  position: absolute;
  bottom: 10rpx;
  left: 50%;
  transform: translateX(-50%);
  transition: all .4s ease;
}

.body-box {
  margin-top: 10rpx;
  margin-bottom: 50rpx;
}

.add-topic-post {
  position: fixed;
  bottom: 60rpx;
  text-align: center;
  z-index: 99;
  width: 100%;
}

.add-topic-post-btn {
  position: fixed;
  bottom: 60rpx;
  text-align: center;
  z-index: 98;
  width: 100%;
}

.add-post-ctrl {
  width: 260rpx;
  line-height: 80rpx;
  height: 80rpx;
  color: #444;
  border-radius: 80rpx;
  margin: 0 auto;
  vertical-align: middle;
}

.add-post-ctrl view {
  height: 80rpx;
  width: 80rpx;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 80rpx;
  background: #333333;
}

.add-post-ctrl image {
  height: 32rpx;
  width: 32rpx;
}

.add-post-animation {
  width: 80rpx;
  animation-duration: 0.5s;
  animation-name: add-post-animation;
  animation-iteration-count: 1;
  animation-direction: alternate;
}

@keyframes add-post-animation {
  from {
    opacity: 0;
    width: 260rpx;
    background: #333333;
  }

  to {
    opacity: 1;
    width: 80rpx;
    background: rgba(0, 88, 162, 0);
  }
}

.add-post-animation2 {
  display: none;
  opacity: 0;
  animation-duration: 0.5s;
  animation-name: add-post-animation2;
  animation-iteration-count: 1;
  animation-direction: alternate;
}

@keyframes add-post-animation2 {
  from {
    opacity: 1;
    width: 80rpx;
    background: rgba(0, 88, 162, 0);
  }

  to {
    opacity: 0;
    width: 260rpx;
    background: #333333;
  }
}

.add-topic-post-option {
  height: 80rpx;
  color: #444;
  text-align: center;
  background: #FFF;
  border-radius: 80rpx;
  margin: 0 auto;
  overflow: hidden;
  width: 260rpx;
  box-shadow: 3rpx 3rpx 30rpx rgba(99, 99, 99, 0.3);
}

.add-post-icon-box {
  width: 250rpx;
  display: flex;
  align-items: center;
  padding: 0 5rpx;
}

.add-post-icon {
  height: 80rpx;
  width: 100rpx;
  text-align: center;
  display: inline-block;
}

.add-post-icon image {
  height: 44rpx;
  width: 44rpx;
  margin-top: 12rpx;
  vertical-align: top;
}

.add-post-icon text {
  display: block;
  text-align: center;
  font-weight: bold;
  margin-top: -4rpx;
  font-size: 14rpx;
}

.add-post-icon-center {
  height: 80rpx;
  width: 60rpx;
  text-align: center;
  display: inline-block;
}

.add-post-icon-center view {
  height: 50rpx;
  width: 50rpx;
  margin: 15rpx auto;
  border-radius: 50rpx;
  background: #333333;
}

.add-post-icon-center image {
  height: 50rpx;
  width: 50rpx;
}

.add-option-animation {
  width: 80rpx;
  animation-duration: 0.5s;
  animation-name: add-option-animation;
  animation-iteration-count: 1;
  animation-timing-function: ease-out;
  animation-direction: alternate;
}

@keyframes add-option-animation {
  from {
    width: 260rpx;
    background: rgba(0, 88, 162, 0);
  }

  to {
    width: 80rpx;
    background: #333333;
  }
}

.add-option-animation2 {
  animation-duration: 0.5s;
  animation-name: add-option-animation2;
  animation-iteration-count: 1;
  animation-timing-function: ease-out;
  animation-direction: alternate;
}

@keyframes add-option-animation2 {
  from {
    width: 80rpx;
  }

  to {
    width: 260rpx;
  }
}

.add-option-animation-drift2 {
  opacity: 1;
  animation-duration: 0.5s;
  animation-name: add-option-animation-drift2;
  animation-iteration-count: 1;
  animation-timing-function: ease-out;
  animation-direction: alternate;
}

@keyframes add-option-animation-drift2 {
  from {
    margin-left: -90rpx;
  }

  to {
    opacity: 1;
    margin-left: 0rpx;
  }
}

.add-option-animation-drift {
  opacity: 0;
  animation-duration: 0.5s;
  animation-name: add-option-animation-drift;
  animation-iteration-count: 1;
  animation-timing-function: ease-out;
  animation-direction: alternate;
}

@keyframes add-option-animation-drift {
  from {
    margin-left: 0rpx;
  }

  to {
    opacity: 1;
    margin-left: -90rpx;
  }
}