.dialog-list {
  padding-bottom: 200rpx;
}

.dialog-item {
  display: flex;
  align-items: center;
  height: 140rpx;
  padding-left: 30rpx;
  padding-right: 30rpx;
  border: none;
  background: none;
  animation: fadeIn 0.5s ease;
}

.dialog-item .item-head {
  position: relative;
  width: 90rpx;
  height: 90rpx;
}

.dialog-item .icon {
  border-radius: 50%;
  display: block;
  width: 90rpx;
  height: 90rpx;
  margin-right: 30rpx;
}

.dialog-item .red-dot {
  display: block;
  height: 32rpx;
  line-height: 32rpx;
  background-color: #ff6d6d;
  border-radius: 32rpx;
  font-size: 20rpx;
  color: #fff;
  padding: 0 12rpx;
}

.dialog-item .item-head .red-dot {
  position: absolute;
  right: -4rpx;
  top: -4rpx;
  width: 16rpx;
  height: 16rpx;
}

.dialog-item .item-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: flex-start;
  margin-left: 30rpx;
  text-align: left;
}

.dialog-item .item-body .info {
  height: 50rpx;
  line-height: 50rpx;
  width: 100%;
  display: flex;
  align-items: center;
  margin: 0;
}

.dialog-item .item-body .name {
  font-size: 30rpx;
  color: #333333;
  width: 300rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.dialog-item .item-body .official-icon {
  width: 54rpx;
  height: 28rpx;
  margin-left: 10rpx;
}

.dialog-item .item-body .time {
  flex: 1;
  color: #949494;
  font-size: 22rpx;
  text-align: right;
}

.dialog-item .item-body .content {
  height: 44rpx;
  line-height: 44rpx;
  width: 100%;
  display: flex;
  justify-content: flex-end;
  align-items: center;
  margin: 0;
}

.dialog-item .item-body .desc {
  flex: 1;
  height: 100%;
  font-size: 24rpx;
  color: #949494;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.right {
  width: 140rpx;
  height: 140rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ff6d6d;
  color: #fff;
  font-size: 28rpx;
}