<wxs module="filters" src="../../../utils/fixed.wxs"></wxs>
<navBar background="white" iconTheme="{{iconTheme}}" bindsearch="goToSearch" searchBar="{{true}}"
  searchText="{{hot_search}}">
</navBar>
<view class="container">
  <view class="loading">
    <image mode="aspectFit" src="/image/load.gif"></image>
  </view>
  <l-skeleton l-class="l-skeleton" loading="{{topload}}" rows="2" title="{{false}}" rows-width="{{['690rpx','690rpx']}}"
    rows-height="{{['140rpx','140rpx']}}">
    <view class="set-content">
      <view class="qh-news-lightbox" wx:if="{{index<5}}" wx:for="{{toplist}}" wx:key="index">
        <image data-id="{{item.id}}" catchtap="routeClubDetail" class="qh-news-lightimg" wx:if="{{index==0}}"
          src="{{item.head_portrait}}" mode="aspectFill"></image>
        <view class="qh-news-lighttext {{index==0?'b1':'be'}}" data-id="{{item.id}}" catchtap="routeClubDetail">
          <view class="qh-news-lihgttitle">
            <image class="qzimage" src="/image/circle.png" /><text>{{item.circle_name}}</text>
          </view>
          <view>{{filters.toFix(item.posts_count)}}</view>
        </view>
      </view>
      <view class="all-circle" catchtap="setNewCircle">
        全部圈子<view class="arrow"></view>
      </view>
    </view>
  </l-skeleton>
  <l-sticky scrollTop="{{scrollTop}}" mode="css">
    <l-sticky-item top="{{customBar}}" l-header-sticky-class="header-sticky-class">
      <view slot="header" class="nav {{currentItem==1?'border':''}}">
        <view bindtap="select" class="tag-box" data-id="{{item.id}}" wx:for="{{taga}}" wx:for-index="i" wx:key="id">
          <view class="taga-item {{currentItem==item.id?'active':''}}" data-id="{{item.id}}">{{item.text}}</view>
        </view>
      </view>
      <view slot="body" class="body-box">
        <block wx:if="{{currentItem===0}}">
          <l-skeleton l-class="l-skeleton" loading="{{hotload}}" rows="2" title="{{false}}"
            rows-width="{{['690rpx','690rpx']}}" rows-height="{{['100rpx','100rpx']}}">
            <scroll-view bindtap="more" scrollX class="hot-search-content" style="white-space: nowrap;">
              <view class="first-content">
                <view data-id="{{item.id}}"
                  class="hot-search-item {{index==0?'margin-left':''}} {{index==tags.length-1?'margin-right':''}}"
                  wx:if="{{index < 8}}" wx:for="{{cats}}" wx:key="unique">
                  <image class="xclimage" src="/image/topic.png" /><text>{{item.plate_name}}</text>
                  <view class="hot" wx:if="{{index%3==0}}">
                    <image mode="aspectFill" src="/image/hot_search_icon.png"></image>
                  </view>
                </view>
              </view>
              <view class="first-content">
                <view data-id="{{item.id}}"
                  class="hot-search-item {{index==8?'margin-left':''}} {{index==tags.length-1?'margin-right':''}}"
                  wx:if="{{index >= 8 && index < 16}}" wx:for="{{cats}}" wx:key="unique">
                  <image class="xclimage" src="/image/topic.png" /><text>{{item.plate_name}}</text>
                  <view class="hot" wx:if="{{index%2==0}}">
                    <image mode="aspectFill" src="/image/hot_search_icon.png"></image>
                  </view>
                </view>
              </view>
            </scroll-view>
          </l-skeleton>
        </block>

        <l-skeleton l-class="l-skeleton" loading="{{subcatsloading}}" rows="3" paragraph="true" title="{{false}}"
          rows-width="{{['690rpx','690rpx','690rpx']}}" rows-height="{{['200rpx','160rpx','160rpx']}}">
          <block wx:if="{{currentItem===0?subcats.length > 0:uSubcats.length > 0}}">
            <view catchtap="routeClubDetail" data-id="{{item.id}}" class="item-list"
              wx:for="{{currentItem===0?subcats:uSubcats}}" wx:key="index">
              <view class="circle-top">
                <view>
                  <view class="club-name">
                    <image class="climage" src="/image/circle-mix.png" />{{item.circle_name}}
                  </view>
                  <view class="area-club-creater" style="color:#333">
                    <text>{{item.posts_count}}条动态</text>
                    <view class="shu"></view>
                    <text>{{item.user_circle_count}}圈友在讨论</text>
                  </view>
                </view>
                <view class="set-focus" data-id="{{item.clubId}}"
                  style="background: url({{item.head_portrait}}) center/cover no-repeat #f5f5f5;"
                  data-index="{{index}}">
                  <view class="circle-icon-box">
                    <image src="/image/jump.png"></image>
                  </view>
                </view>
              </view>
              <view class="circle-box" wx:for="{{item.wx_posts}}" wx:for-item="itemPosts" wx:key="index"
                wx:if="{{index<2}}">
                <image class="circle-box-icon" src="/image/themessage.png" />
                <image class="circle-box-icon-img" wx:if="{{itemPosts.commment_count==0}}" src="/image/more.png" />
                <view class="circle-box-icon-text" wx:else>
                  {{itemPosts.commment_count > 99 ? '99+' :itemPosts.commment_count}} </view>
                <rich-text class="circle-box-title" nodes="{{itemPosts.posts_content}}" />
                <image class="circle-box-img" mode="aspectFill" src="{{itemPosts.user.user_avatar}}" />
              </view>
            </view>
            <l-loadmore show="{{loadmoreShow}}" type="{{isLastPage?'end':'loading'}}" end-text="已经到底了" loading-text=""
              size="28" line="{{false}}" color="#949494" />
            <view class="recommend-section" wx:if="{{currentItem===1 && isMore}}">
              <view class="botn-box">
                <view class="setBtn" catchtap="setNewCircle">发现更多圈子
                  <view class="arrow"></view>
                </view>
              </view>
            </view>
          </block>
          <view class="empty-box" wx:else>
            <empty-view icon="http://127.0.0.1/storage/wxprogram/image/Circles-rafiki.png" title="空">
            </empty-view>
            <view class="botn-box">
              <view class="setBtn" catchtap="setNewCircle">发现更多圈子
                <view class="arrow"></view>
              </view>
            </view>
          </view>
        </l-skeleton>
      </view>
    </l-sticky-item>
  </l-sticky>
</view>