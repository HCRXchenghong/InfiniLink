@import "/pages/template/circle.wxss";

.empty-box {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading {
  text-align: center;
}

.loading image {
  width: 68rpx;
  height: 68rpx;
  margin: 20rpx 0rpx;
}

.hero-carousel {
  position: relative;
  margin: 0 30rpx 28rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background: #f3f4f6;
  box-shadow: 0 18rpx 40rpx rgba(15, 23, 42, 0.08);
}

.hero-carousel-swiper {
  height: 300rpx;
}

.hero-carousel-item {
  position: relative;
  width: 100%;
  height: 100%;
}

.hero-carousel-image {
  width: 100%;
  height: 100%;
}

.hero-carousel-mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, rgba(17, 24, 39, 0.82) 0%, rgba(17, 24, 39, 0.28) 100%);
}

.hero-carousel-copy {
  position: absolute;
  inset: 0;
  padding: 28rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.hero-carousel-badge {
  align-self: flex-start;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  color: #ffffff;
  font-size: 20rpx;
  margin-bottom: 18rpx;
}

.hero-carousel-title {
  font-size: 34rpx;
  line-height: 1.4;
  color: #ffffff;
  font-weight: 600;
}

.hero-carousel-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: rgba(255, 255, 255, 0.88);
}

.hero-carousel-button {
  margin-top: 20rpx;
  align-self: flex-start;
  min-width: 160rpx;
  padding: 14rpx 26rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #111827;
  font-size: 24rpx;
  text-align: center;
  font-weight: 600;
}

.hero-carousel-dots {
  position: absolute;
  right: 24rpx;
  bottom: 24rpx;
  display: flex;
  gap: 10rpx;
}

.hero-carousel-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.35);
}

.hero-carousel-dot-active {
  width: 28rpx;
  border-radius: 999rpx;
  background: #ffffff;
}

.logo {
  width: 180rpx;
  height: 60rpx;
  padding-right: 20rpx;
  vertical-align: middle;
}

.index-header {
  height: 80rpx;
  background: white;
  box-sizing: border-box;
  z-index: 9999;
  position: fixed;
  top: 0px;
  width: 100%;
  left: 0;
  display: flex;
  padding-left: 35rpx;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}

.topping {
  padding-bottom: 20rpx;
  margin-bottom: 20rpx;
  border-bottom: 1px solid #f5f5f5;
}

.topping-article {
  padding: 0rpx 30rpx;
}

.recoBox {
  padding: 10rpx 0rpx 20rpx;
  position: relative;
  border-radius: 8rpx;
  overflow: hidden;
}

.recommend {
  text-align: center;
  position: relative;
  border-radius: 8rpx;
  overflow: hidden;
}

.rp4 {
  padding-bottom: 98rpx;
}

.rp5 {
  padding-bottom: 196rpx;
}

.recommend:nth-of-type(1),
.recommend:nth-of-type(6) {
  width: 462rpx;
  height: 186rpx;
  line-height: 186rpx;
  font-size: 36rpx;
  animation: fadeIn 0.5s ease;
}

.recommend:nth-of-type(1) {
  float: left;
}

.recommend:nth-of-type(2),
.recommend:nth-of-type(3),
.recommend:nth-of-type(4),
.recommend:nth-of-type(5) {
  width: 222rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 24rpx;
}

.recommend:nth-of-type(2),
.recommend:nth-of-type(3) {
  float: right;
}

.recommend:nth-of-type(3) {
  margin-top: 10rpx;
}

.recommend:nth-of-type(4),
.recommend:nth-of-type(5) {
  position: absolute;
}

.recommend:nth-of-type(4) {
  top: 206rpx;
}

.recommend:nth-of-type(5) {
  top: 304rpx;
}

.recommend:nth-of-type(6) {
  float: right;
  margin-top: 10rpx;
}

.recoTitle {
  color: #fff;
  width: 80%;
  line-height: 135%;
  vertical-align: middle;
  word-wrap: break-word;
  overflow: hidden;
  text-overflow: -o-ellipsis-lastline;
  text-overflow: ellipsis;
  display: -webkit-inline-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  position: relative;
  z-index: 1;
}

.recommend:nth-of-type(2) .recoTitle,
.recommend:nth-of-type(5) .recoTitle {
  color: #000;
}

.linearMask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.lm_1 {
  background: #000000;
  opacity: 0.3;
}

.lm_2 {
  background: #000000;
  opacity: 0.6;
}

.lm_3 {
  background: linear-gradient(to right, #f5f6f7, #e5eaf0);
  opacity: 1;
}

.tab-view::before {
  content: '';
  position: absolute;
  -webkit-transform: scaleY(0.5);
  transform: scaleY(0.5);
  bottom: 0;
  right: 0;
  left: 0;
}

.tab-view {
  width: 100%;
  height: 80rpx;
  overflow: hidden;
  box-sizing: border-box;
  white-space: nowrap;
  position: fixed;
  left: 0;
  padding-right: 100rpx;
  z-index: 99;
  background: #fff;
}

.tab-bar-item {
  padding: 0;
  height: 80rpx;
  min-width: 80rpx;
  line-height: 80rpx;
  margin: 0 28rpx;
  display: inline-block;
  text-align: center;
  box-sizing: border-box;
}

.tab-bar-title {
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  color: #949494;
  font-weight: 450;
  font-family: "PingFang SC Medium";
  animation: fadeIn 0.2s ease;
}

.active .tab-bar-title {
  font-size: 34rpx;
  color: #333333;
  font-weight: bold;
  font-family: "PingFang SC Heavy";
}

.active {
  position: relative;
}

.active:after {
  content: "";
  display: block;
  width: 16rpx;
  height: 6rpx;
  background: #333333;
  border-radius: 6rpx;
  position: absolute;
  bottom: 8rpx;
  left: 50%;
  transform: translateX(-50%);
  transition: all .4s ease;
}

.tab-more {
  position: fixed;
  display: flex;
  align-items: center;
  justify-content: center;
  right: 0;
  height: 80rpx;
  width: 100rpx;
  z-index: 99;
  background: white;
  box-shadow: -10px 0 13px -16px #949494;
}

.tab-more image {
  height: 42rpx;
  width: 42rpx;
  margin-right: 10rpx;
}

.splash-ad-overlay {
  position: fixed;
  inset: 0;
  z-index: 99999;
  background: rgba(15, 23, 42, 0.72);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  box-sizing: border-box;
}

.splash-ad-skip {
  position: absolute;
  top: 80rpx;
  right: 40rpx;
  min-width: 116rpx;
  padding: 14rpx 0;
  text-align: center;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  color: #ffffff;
  font-size: 24rpx;
}

.splash-ad-card-shell {
  position: relative;
  width: 100%;
  max-width: 620rpx;
}

.splash-ad-close {
  position: absolute;
  top: 18rpx;
  right: 18rpx;
  z-index: 2;
  width: 64rpx;
  height: 64rpx;
  border-radius: 999rpx;
  background: rgba(15, 23, 42, 0.58);
  color: #ffffff;
  font-size: 40rpx;
  line-height: 64rpx;
  text-align: center;
  box-sizing: border-box;
}

.splash-ad-card {
  width: 100%;
  border-radius: 28rpx;
  overflow: hidden;
  background: #ffffff;
  box-shadow: 0 24rpx 60rpx rgba(15, 23, 42, 0.22);
}

.splash-ad-image {
  width: 100%;
  height: 620rpx;
  display: block;
}

.splash-ad-content {
  padding: 28rpx 28rpx 32rpx;
}

.splash-ad-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #111827;
  color: #ffffff;
  font-size: 20rpx;
}

.splash-ad-title {
  margin-top: 20rpx;
  font-size: 34rpx;
  line-height: 1.45;
  color: #111827;
  font-weight: 600;
}

.splash-ad-subtitle {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #4b5563;
}

.splash-ad-button {
  margin-top: 24rpx;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 999rpx;
  background: #2563eb;
  color: #ffffff;
  text-align: center;
  font-size: 26rpx;
  font-weight: 600;
}
