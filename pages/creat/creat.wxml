<view class="containers" bindtouchstart="onUserTouchActivity">
    <view bindtap="creatForums" class="top-button-confirm">
        <image src="/image/add.png" />发布
    </view>
    <view class="membership-post-entry membership-post-entry-{{membershipPostPrompt.tone}}" wx:if="{{membershipPostPrompt}}">
        <view class="membership-entry-header">
            <text class="membership-entry-badge">{{membershipPostPrompt.badge}}</text>
            <text class="membership-entry-title">{{membershipPostPrompt.title}}</text>
        </view>
        <view class="membership-entry-desc">{{membershipPostPrompt.desc}}</view>
        <view class="membership-entry-items">
            <view class="membership-entry-item" wx:for="{{membershipPostPrompt.entries}}" wx:key="title"
                wx:for-item="entry">
                <text class="membership-entry-item-label">{{entry.title}}</text>
                <text class="membership-entry-item-value">{{entry.value}}</text>
            </view>
        </view>
        <view bindtap="onMembershipPostActionTap" class="membership-entry-action"
            data-action="{{membershipPostPrompt.action}}" data-scene="{{membershipPostPrompt.scene}}">
            {{membershipPostPrompt.buttonText}}
        </view>
    </view>
    <textarea auto-height bindinput="onContentInput" bindfocus="onUserInputActivity" bindblur="bCursor" class="content-text" maxlength="3000"
        placeholder="想说你就多说点" placeholder-class="content-placeholder" value="{{textinput}}"></textarea>

    <view class="middle-mix">
        <image wx:for="{{menusMix}}" wx:key="idx" bindtap="onMixMenuItem" data-index="{{index}}" src="{{item}}"></image>
        <view>{{textLength}}/{{textLengthMix}}</view>
    </view>

    <view class="content-media" wx:if="{{mediaType!=-1}}">
        <view class="media-picture" wx:if="{{mediaType==0}}">
            <view bindtap="onPreviewPicture" class="picture-item" data-src="{{item.url}}" data-pic="{{image_urls}}"
                wx:for="{{image_urls}}" wx:key="index">
                <image class="picture-image" mode="aspectFill" src="{{item.url}}"></image>
                <image catchtap="onPictureDelete" class="picture-delete" data-index="{{index}}"
                    src="/image/icon_delete_buoy.png"></image>
            </view>
            <view bindtap="addPictures" class="picture-item-add"
                wx:if="{{image_urls==null||image_urls==''||image_urls.length<pictureMax}}">
                <image class="picture-add-image" src="/image/new_construction_circle_cover_upload_picture.png">
                </image>
            </view>
        </view>

        <block wx:elif="{{mediaType==1}}">
            <view class="media-video" wx:if="{{video_url!=''}}">
                <video class="video-source" controls="true" src="{{video_url}}"></video>
                <image bindtap="onVideoDelete" class="picture-delete" src="/image/icon_delete_buoy.png"></image>
            </view>
        </block>
    </view>

    <view class="middle">
        <block wx:if="{{mediaType==-1}}">
            <view bindtap="onMenuItem" class="menu-item" data-index="{{idx}}" wx:for="{{menus}}" wx:for-index="idx"
                wx:key="idx">
                <image class="item-icon" src="{{item.icon}}"></image>
                <!-- <text class="item-text">{{item.text}}</text> -->
            </view>
        </block>
    </view>

    <view class="bottom">
        <view bindtap="onTopicClick" class="bottom-item">
            <image class="bottom-item-icon" src="/image/circle-mix.png"></image>
            <text class="bottom-item-text">圈子</text>
            <view class="address-tag-all-view bottom-item-text-selected {{topicids==''?'':'c3'}}">
                {{topicids==''?'与圈友讨论':topic}}
            </view>
            <view class="bottom-item-arrow" />
        </view>
        <view bindtap="onTagClick" class="bottom-item">
            <image class="bottom-item-icon" src="/image/topic.png"></image>
            <view class="bottom-item-text">标签</view>
            <scroll-view scrollX enableFlex="enable-flex" enhanced="enhanced"
                scrollWithAnimation="scroll-with-animation" showScrollbar="{{false}}" class="address-tag-all-view">
                <view class="bottom-item-text-selected" wx:if="{{tags.length <= 0}}">
                    与更多人分享
                </view>
                <view class="tag-view" wx:for="{{tags}}" wx:key="index" wx:for-item="tag">
                    # {{tag.tags_name}}
                </view>
            </scroll-view>
            <view class="bottom-item-arrow" />
        </view>
        <view bindtap="onLocationClick" class="bottom-item">
            <image class="bottom-item-icon" src="/image/loc_icon_show.png"></image>
            <text class="bottom-item-text">{{locationState?'位置':location.address_detailed}}</text>
            <view class="address-tag-all-view bottom-item-text-selected" wx:if="{{locationState}}">
                让附近的人康康
            </view>
            <image wx:else src="/image/del_biaoq.png" class="del_adds" catchtap="delAddsTap"></image>
            <view class="bottom-item-arrow" />
        </view>
    </view>
</view>

<l-popup show="{{linkPopup}}" bind:lintap="toAddLink" animation="true" z-index="999">
    <view class="link-box">
        <view class="link-popup-title">添加超链接
            <image src="/image/close-fill.png" catchtap="toAddLink" />
        </view>
        <view class="link-input">
            <view>名称：</view>
            <input placeholder="请输入链接显示名称" value="{{linkName}}" data-type="0" bindfocus="onUserInputActivity" bindinput="onLinkInput" />
        </view>
        <view class="link-input">
            <view>链接：</view>
            <input placeholder="请输入链接地址（要带https://哦）" cursor="9" data-type="1" value="{{linkAdds}}"
                bindfocus="onUserInputActivity" bindinput="onLinkInput" />
        </view>
        <view class="link-add-btn" bindtap="openAddLink">确认添加</view>
    </view>
</l-popup>

<custom-tab-bar selected="{{2}}" color="#949494" selectedColor="#333333" fontSize="22" list="{{tabbar}}">
</custom-tab-bar>
