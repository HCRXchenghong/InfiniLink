.box {
  width: 690rpx;
  margin: 0 auto;
}

.box-top {
  width: 100%;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-bottom: 10rpx;
}

.box-top-title {
  font-size: 28rpx;
  color: #333333;
  display: flex;
  align-items: center;
}

.box-top-title .des {
  font-size: 24rpx;
  color: #949494;
  margin-left: 10rpx;
}

.box-top-etn {
  width: 90rpx;
  height: 55rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #fff;
  background: #333333;
  border-radius: 8rpx;
}

.box-plate {
  display: flex;
  position: relative;
  flex: row;
  align-items: center;
  flex-wrap: wrap;
}

.box-plate-coent {
  position: relative;
  padding: 0 40rpx;
  margin-bottom: 20rpx;
  margin-right: 16rpx;
  height: 70rpx;
  display: flex;
  align-items: center;
  border-radius: 500rpx;
  font-size: 28rpx;
  color: #333;
  background: #f5f5f5;
  animation: fadeIn 0.6s ease;
}

.add {
  background: #fff !important;
  border: 1px dashed #949494;
}

.audio-img {
  position: absolute;
  padding: 20rpx;
  width: 30rpx;
  height: 30rpx;
  top: -30rpx;
  right: -30rpx;
}

.cor {
  color: #949494 !important;
}