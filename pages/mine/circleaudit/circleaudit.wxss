::-webkit-scrollbar {
  width: 0;
  height: 0;
  color: transparent;
}

.container {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  overflow-x: hidden;
}

.right-items {
  position: absolute;
  height: 100%;
}

.area-club {
  width: 720rpx;
  margin-left: 30rpx;
  height: 200rpx;
  display: flex;
  align-items: center;
  position: relative;
  border-bottom: 1px solid #f5f5f5;
}

.area-club:last-child {
  margin-bottom: 50rpx !important;
}

.area-club .image {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
}

.area-club-info {
  margin-left: 30rpx;
  width: 400rpx;
}

.area-club-name {
  font-size: 28rpx;
  color: #333333;
  width: 100%;
  white-space: nowrap;
  font-weight: bold;
  overflow: hidden;
  text-overflow: ellipsis;
}

.area-club-creater {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #333;
}

.shu {
  width: 3rpx;
  height: 18rpx;
  background: #333333;
  margin: 0 10rpx;
}

.mt-6 {
  font-size: 24rpx;
  color: #949494;
  margin: 6rpx 0;
  width: 100%;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.editor-box {
  margin-left: 40rpx;
  width: 120rpx;
  height: 120rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.btn {
  width: 120rpx;
  height: 50rpx;
  font-size: 24rpx;
  font-weight: 500;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.s {
  border: 1px solid #333;
  background: #333333;
  color: #fff;
}

.k {
  border: 1px solid #333;
  background: #fff;
  color: #333333;
}

.loading {
  text-align: center;
}

.loading image {
  width: 80rpx;
  height: 80rpx;
  margin: 40rpx 0rpx;
}

.empty-view {
  margin-top: 100rpx;
}