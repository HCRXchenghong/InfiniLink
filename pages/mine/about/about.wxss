.box {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  animation: fadeIn 1s ease;
}

.img {
  margin-top: 200rpx;
  width: 120rpx;
  height: 120rpx;
  border-radius: 18rpx;
  background: #f5f5f5;
}

.version {
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #000;
}

.box-content {
  margin-top: 40rpx;
  font-size: 28rpx;
  color: #333333;
}

.copyright-information {
  position: fixed;
  z-index: 9;
  bottom: 30rpx;
  font-size: 24rpx;
  color: #949494;
}

.account {
  margin: 50rpx auto;
  width: 300px;
  height: 84px;
  border-radius: 8rpx;
}