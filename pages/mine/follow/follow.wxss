.container {
  width: 100%;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.load-log {
  margin-top: 120rpx;
  width: 68rpx;
  height: 68rpx;
}

.empty-view {
  margin-top: 60rpx;
}

.user-list {
  width: 100%;
}

.user-item {
  display: flex;
  align-items: center;
  padding: 0 32rpx;
  height: 140rpx;
}

.user-item .avatars {
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  background-color: #f5f5f5;
}

.user-item .infos {
  flex: 1;
  margin: 0 30rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.user-item .nickname {
  flex: 1;
  line-height: 50rpx;
  height: 50rpx;
  font-size: 30rpx;
  width: 100%;
  color: #333;
  margin: 0;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.user-item .follow-btn {
  width: 120rpx;
  height: 55rpx;
  line-height: 55rpx;
  border-radius: 10rpx;
  font-size: 26rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #333333;
  padding: 0;
  border: 1px solid #333333;
  background-color: #ffffff;
}

.follow {
  width: 160rpx !important;
  color: #949494 !important;
  background-color: #f5f5f5 !important;
  border: 1px solid #f5f5f5 !important;
}