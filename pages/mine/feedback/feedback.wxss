.container {
  width: 690rpx;
  margin: 30rpx auto;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  align-items: center;
  box-sizing: border-box;
}

.support-entry {
  width: 100%;
  margin-bottom: 24rpx;
  padding: 24rpx;
  box-sizing: border-box;
  border-radius: 20rpx;
  background: #141414;
}

.support-entry-badge {
  display: inline-flex;
  min-width: 120rpx;
  height: 40rpx;
  padding: 0 16rpx;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.14);
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 700;
}

.support-entry-title {
  margin-top: 16rpx;
  font-size: 30rpx;
  line-height: 42rpx;
  color: #ffffff;
  font-weight: 700;
}

.support-entry-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 36rpx;
  color: rgba(255, 255, 255, 0.78);
}

.item {
  position: relative;
  width: 100%;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  align-items: flex-start;
  box-sizing: border-box;
  padding-top: 34rpx;
  padding-right: 32rpx;
  border-bottom: 1px solid #f5f5f5;
}

.item-title {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.item-tip {
  position: absolute;
  top: 36rpx;
  right: 32rpx;
  font-size: 24rpx;
  color: #949494;
}

.item-area {
  width: 100%;
  height: 300rpx;
  font-size: 32rpx;
  color: #333333;
  box-sizing: border-box;
  padding: 32rpx 0;
}

.item-h {
  width: 100%;
  height: 112rpx;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  box-sizing: border-box;
  padding-right: 32rpx;
  border-bottom: 1px solid #f5f5f5;
}

.bottom {
  margin-top: 50rpx;
  width: 70%;
  height: 90rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #333;
  font-weight: bold;
  color: #FFFFFF;
  font-size: 28rpx;
  box-shadow: 0px -1px 4px 0px rgba(197, 202, 213, 0.25);
}

.picker {
  color: #333;
  font-size: 28rpx;
  display: flex;
  align-items: center;
}

.arrow {
  margin-left: 10rpx;
  width: 10rpx;
  height: 10rpx;
  border-top: 4rpx solid #333;
  border-right: 4rpx solid #333;
  transform: rotate(45deg);
}
