.loading {
  text-align: center;
}

.loading image {
  width: 80rpx;
  height: 80rpx;
  margin: 40rpx 0rpx;
}

.box {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.box image {
  margin: 80rpx 0 30rpx;
  width: 300rpx;
  height: 300rpx;
  animation: fadeIn 1s ease;
}

.box text {
  font-size: 28rpx;
  color: #444444;
  padding: 10rpx 0;
}

.box view {
  margin: 120rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  background: #333333;
  color: #FFFFFF;
  border-radius: 10rpx;
}

.notice-bar {
  background: #333333 !important;
  color: #FFFFFF !important;
  font-size: 26rpx !important;
}

.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
}

.content-container {
  width: 690rpx;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  align-items: center;
  box-sizing: border-box;
}

.img-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
}

.logo-container {
  position: relative;
  width: 300rpx;
  height: 300rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  box-sizing: border-box;
  background: #f5f5f5;
  border-radius: 8rpx;
  margin-top: 40rpx;
  margin-bottom: 40rpx;
}

.logo-add {
  width: 64rpx;
  height: 64rpx;
}

.logo-image {
  width: 300rpx;
  height: 300rpx;
  border-radius: 8rpx;
}

.img-text {
  font-size: 24rpx;
  color: #949494;
}

.logo-camera {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 500rpx;
  background: rgba(0, 0, 0, 0.3);
}

.item {
  position: relative;
  width: 100%;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  align-items: flex-start;
  box-sizing: border-box;
  padding-top: 34rpx;
  border-bottom: 1px solid #f5f5f5;
}

.item-title {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.item-input {
  width: 100%;
  height: 94rpx;
  line-height: 94rpx;
  font-size: 32rpx;
  color: #333333;
}

.item-h-tip {
  width: 100%;
  line-height: 32rpx;
  font-size: 24rpx;
  color: #949494;
  box-sizing: border-box;
}

.item-tip {
  position: absolute;
  top: 36rpx;
  right: 32rpx;
  font-size: 24rpx;
  color: #949494;
}

.item-area {
  width: 100%;
  height: 250rpx;
  font-size: 32rpx;
  color: #333333;
  box-sizing: border-box;
  padding: 32rpx 0;
}

.bottom-tip-text {
  width: 100%;
  font-size: 24rpx;
  color: #949494;
  box-sizing: border-box;
  margin-top: 32rpx;
}

.bottom-button {
  width: 300rpx;
  height: 82rpx;
  font-size: 28rpx;
  color: #FFFFFF;
  background: #333333;
  border-radius: 500rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}