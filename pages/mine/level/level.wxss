.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 40rpx;
  box-sizing: border-box;
  background: #f6f7fb;
}

.hero-card,
.panel {
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 12rpx 36rpx rgba(15, 23, 42, 0.05);
}

.hero-card {
  padding: 30rpx 28rpx;
  background: linear-gradient(135deg, #111827 0%, #374151 100%);
}

.hero-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.hero-main {
  min-width: 0;
  flex: 1;
}

.hero-badge {
  min-width: 108rpx;
  height: 52rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.hero-rank {
  margin-top: 16rpx;
  font-size: 40rpx;
  line-height: 52rpx;
  color: #ffffff;
  font-weight: 700;
}

.hero-score {
  margin-top: 10rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.92);
  font-weight: 700;
}

.hero-member {
  flex-shrink: 0;
  max-width: 280rpx;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.12);
  color: #ffffff;
  font-size: 20rpx;
  line-height: 28rpx;
  box-sizing: border-box;
}

.hero-member-member {
  color: #fde68a;
}

.hero-title {
  margin-top: 22rpx;
  font-size: 34rpx;
  line-height: 46rpx;
  color: #ffffff;
  font-weight: 700;
}

.hero-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 38rpx;
  color: rgba(255, 255, 255, 0.84);
}

.hero-meta {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  font-size: 24rpx;
  line-height: 36rpx;
  color: rgba(255, 255, 255, 0.78);
}

.progress-track {
  margin-top: 24rpx;
  width: 100%;
  height: 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
}

.hero-chip-row {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.hero-chip {
  min-height: 44rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  display: inline-flex;
  align-items: center;
  box-sizing: border-box;
}

.panel {
  margin-top: 24rpx;
  padding: 28rpx 24rpx;
}

.panel-title {
  font-size: 30rpx;
  line-height: 42rpx;
  color: #111827;
  font-weight: 700;
}

.panel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.panel-link,
.panel-tip {
  flex-shrink: 0;
  font-size: 22rpx;
  color: #2563eb;
}

.overview-grid {
  margin-top: 20rpx;
  display: flex;
  flex-wrap: nowrap;
  gap: 12rpx;
}

.overview-card {
  flex: 1;
  min-width: 0;
  min-height: 122rpx;
  padding: 16rpx 14rpx 18rpx;
  border-radius: 18rpx;
  background: #f8fafc;
  box-sizing: border-box;
}

.overview-label {
  font-size: 20rpx;
  line-height: 28rpx;
  color: #6b7280;
}

.overview-value {
  margin-top: 8rpx;
  font-size: 26rpx;
  line-height: 36rpx;
  color: #111827;
  font-weight: 700;
  word-break: break-word;
}

.overview-note {
  margin-top: 6rpx;
  font-size: 18rpx;
  line-height: 26rpx;
  color: #4b5563;
}

.level-gallery-scroll {
  margin-top: 20rpx;
  width: 100%;
  white-space: nowrap;
}

.level-gallery-row {
  display: inline-flex;
  gap: 16rpx;
  padding-right: 8rpx;
}

.level-card {
  width: 260rpx;
  min-height: 274rpx;
  padding: 20rpx 18rpx 22rpx;
  border-radius: 22rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.level-card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
}

.level-card-badge {
  min-width: 84rpx;
  height: 40rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.level-card-status {
  min-width: 88rpx;
  height: 36rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.14);
  color: rgba(255, 255, 255, 0.92);
  font-size: 18rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.level-card-status-current {
  background: rgba(255, 255, 255, 0.22);
  color: #ffffff;
}

.level-card-status-done {
  background: rgba(15, 23, 42, 0.18);
  color: rgba(255, 255, 255, 0.92);
}

.level-card-status-locked {
  background: rgba(255, 255, 255, 0.10);
  color: rgba(255, 255, 255, 0.72);
}

.level-card-title {
  margin-top: 18rpx;
  font-size: 34rpx;
  line-height: 44rpx;
  font-weight: 700;
}

.level-card-aura {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 30rpx;
  color: rgba(255, 255, 255, 0.88);
  font-weight: 600;
}

.level-card-desc {
  margin-top: 14rpx;
  font-size: 22rpx;
  line-height: 34rpx;
  white-space: normal;
}

.metric-grid {
  margin-top: 20rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.metric-card {
  width: calc(50% - 8rpx);
  min-height: 116rpx;
  padding: 18rpx 18rpx 20rpx;
  border-radius: 18rpx;
  background: #f8fafc;
  box-sizing: border-box;
}

.metric-label {
  font-size: 22rpx;
  line-height: 30rpx;
  color: #6b7280;
}

.metric-value {
  margin-top: 10rpx;
  font-size: 26rpx;
  line-height: 36rpx;
  color: #111827;
  font-weight: 700;
  word-break: break-word;
}

.metric-note {
  margin-top: 8rpx;
  font-size: 20rpx;
  line-height: 30rpx;
  color: #4b5563;
}

.tip-item {
  margin-top: 18rpx;
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.tip-index {
  flex-shrink: 0;
  min-width: 50rpx;
  height: 50rpx;
  border-radius: 999rpx;
  background: #111827;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 700;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.tip-content {
  min-width: 0;
  flex: 1;
}

.tip-title {
  font-size: 24rpx;
  line-height: 34rpx;
  color: #111827;
  font-weight: 700;
}

.tip-desc {
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 36rpx;
  color: #4b5563;
}

.action-card {
  margin-top: 24rpx;
  padding: 26rpx 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 30rpx rgba(15, 23, 42, 0.04);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.action-copy {
  min-width: 0;
  flex: 1;
}

.action-title {
  font-size: 28rpx;
  line-height: 40rpx;
  color: #111827;
  font-weight: 700;
}

.action-desc {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 34rpx;
  color: #4b5563;
}

.action-button {
  flex-shrink: 0;
  min-width: 180rpx;
  height: 72rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #111827;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}
