.header {
  width: 100%;
  height: 200rpx;
  background-color: #fff;
  display: flex;
  align-items: flex-end;
  margin-bottom: 100rpx;
}

.header-image {
  width: 170rpx;
  height: 170rpx;
  border-radius: 500rpx;
  background-color: #f5f5f5;
  margin-left: 48rpx;
}

.info {
  height: 120rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.info-title {
  color: #949494;
  font-size: 28rpx;
  margin-left: 48rpx;
  height: 38rpx;
}

.info-text {
  font-size: 28rpx;
  color: #333;
  margin-left: 48rpx;
  width: 600rpx;
  height: 60rpx;
  line-height: 60rpx;
  font-weight: bold;
}

.info-line {
  height: 1px;
  background-color: #f5f5f5;
  margin-left: 48rpx;
  margin-bottom: 48rpx;
}

.commit {
  position: fixed;
  z-index: 9;
  background: #333;
  color: white;
  font-size: 28rpx;
  height: 90rpx;
  font-weight: bold;
  width: 50%;
  align-items: center;
  justify-content: center;
  display: flex;
  bottom: 60rpx;
  left: 25%;
  border-radius: 500rpx !important;
}

.add_type {
  padding: 40rpx 48rpx 240rpx;
}

.add_type .tips {
  height: 52rpx;
  line-height: 52rpx;
  margin-bottom: 8rpx;
  font-size: 32rpx;
  font-weight: 400;
  color: #949494;
}

.imgs-list {
  position: relative;
  bottom: 0;
  display: flex;
  align-items: flex-end;
  white-space: nowrap;
  padding: 10rpx 10rpx 10rpx 0;
  box-sizing: border-box;
  background: #fff;
  overflow-x: scroll;
  -webkit-overflow-scrolling: touch;
  overflow-y: hidden;
  z-index: 20;
}

.imgs-list::-webkit-scrollbar {
  display: none;
}

.imgs-list .imgs-item {
  display: inline-block;
  width: 210rpx;
  height: 210rpx;
  background: no-repeat center/cover;
  margin: 0 7rpx;
  border-radius: 16rpx;
  position: relative;
  overflow: hidden;
}

.imgs-item.imgs-bg {
  background: #f0f0f0;
}

.imgs-list .imgs-item image {
  width: 210rpx;
  height: 210rpx;
}

.imgs-list .imgs-item.add {
  position: relative;
  border: 1px solid #f5f5f5;
  background: #f5f5f5;
  border-radius: 16rpx;
  box-sizing: border-box;
}

.imgs-list .imgs-item.add::after {
  content: "";
  display: block;
  height: 40px;
  width: 2px;
  background: #949494;
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
}

.imgs-list .imgs-item.add::before {
  content: "";
  display: block;
  height: 2px;
  width: 40px;
  background: #949494;
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
}

.logo-camera {
  margin-left: 10rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #333;
}