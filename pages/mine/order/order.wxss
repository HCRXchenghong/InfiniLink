page {
  background: #f5f5f5;
}

.l-skeleton {
  margin-left: 30rpx;
}

.container {
  padding-bottom: 200rpx;
}

.box {
  width: 630rpx;
  padding: 30rpx;
  margin: 20rpx auto 30rpx;
  background: #fff;
  border-radius: 30rpx;
  box-shadow: 0 2px 24px 0px hsla(0, 0%, 80%, 0.23);
  animation: fadeIn 1s ease;
}

.box-top {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  /* padding-bottom: 20rpx;
  border-bottom: 2rpx solid #000; */
}

.box-top .copy {
  margin-left: 10rpx;
  width: 80rpx;
  height: 44rpx;
  font-size: 24rpx;
  color: #333333;
  background: #f5f5f5;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.box-center {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 0;
}

.box-center-left {
  display: flex;
  flex-direction: column;
}

.box-center-left .title {
  color: #000;
  font-size: 38rpx;
  font-weight: bold;
}

.box-center-left .details {
  color: #444;
  font-size: 26rpx;
  padding: 5rpx 0 20rpx;
}

.box-center-left .date {
  color: #949494;
  font-size: 24rpx;
}

.box-center-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.box-center-right .price-text {
  color: #333;
  font-size: 24rpx;
}

.box-bottom {
  padding-top: 10rpx;
}

.box-bottom .see-posts {
  width: 220rpx;
  height: 70rpx;
  border-radius: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #333333;
  font-weight: bold;
  font-size: 28rpx;
  background: #f5f5f5;
}

.box-bottom .see-posts image {
  width: 38rpx;
  height: 38rpx;
  margin-right: 16rpx;
}

.empty-view {
  margin-top: 100rpx;
}