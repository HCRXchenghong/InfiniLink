@import "/pages/template/circle.wxss";

.search-form {
  display: block;
  width: 100%;
  height: 100rpx;
}

.search-form-inner {
  position: fixed;
  left: 0;
  width: 100%;
  padding: 20rpx 0 20rpx 32rpx;
  height: 100rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-sizing: border-box;
  background-color: #fff;
  z-index: 11;
}

.search-box {
  flex: 1;
  height: 60rpx;
  padding: 0 14rpx 0 18rpx;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  background-color: #f5f5f5;
}

.search-btn {
  width: 120rpx;
  height: 60rpx;
  line-height: 60rpx;
  margin: 0;
  padding: 0;
  border: none;
  background: none;
  font-size: 32rpx;
  color: #333;
}

.search-box .search-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 14rpx;
}

.search-box .input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.search-box .placeholder {
  font-size: 28rpx;
  color: #949494;
}

button::after {
  border-radius: 0;
  border: none;
}

.icon-btn {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  background: none;
  border: none;
  padding: 0;
  width: 64rpx;
  height: 64rpx;
}

.icon-btn .icon {
  display: block;
  width: 32rpx;
  height: 32rpx;
}

.tabs {
  position: fixed;
  z-index: 99;
  margin-top: 96rpx;
  overflow: hidden;
  background-color: #fff;
  width: 100%;
  display: flex;
  flex-wrap: nowrap;
}

.tab,
.tabs {
  height: 88rpx;
}

.tab {
  width: 50%;
  line-height: 88rpx;
  text-align: center;
  box-sizing: border-box;
  position: relative;
  font-family: PingFangSC-Regular;
  font-size: 26rpx;
  color: #949494;
  font-weight: 450;
  letter-spacing: 1.12px;
}

.tabnew {
  font-family: PingFangSC-Medium;
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
  letter-spacing: 1.29px;
}

.line {
  position: absolute;
  bottom: 10%;
  left: 50%;
  transform: translateX(-50%);
  width: 16rpx;
  height: 6rpx;
  background: #333333;
  border-radius: 6rpx;
}

.resultList {
  padding-top: 188rpx;
}

.area-club {
  width: 100%;
  height: 200rpx;
  display: flex;
  align-items: center;
  position: relative;
}

.area-club:last-child {
  margin-bottom: 20rpx;
}

.l-loadmore-two {
  margin-bottom: 100rpx;
}

.area-club .image {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  margin-left: 30rpx;
  margin-right: 16rpx;
}

.area-club-name {
  font-size: 28rpx;
  color: #333333;
  width: 420rpx;
  white-space: nowrap;
  font-weight: bold;
  overflow: hidden;
  text-overflow: ellipsis;
  display: flex;
  align-items: center;
}

.area-club-image {
  width: 38rpx;
  height: 38rpx;
  margin-right: 8rpx;
}

.area-club-creater {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #333;
}

.shu {
  width: 3rpx;
  height: 18rpx;
  background: #333333;
  margin: 0 10rpx;
}

.mt-6 {
  font-size: 24rpx;
  color: #949494;
  margin: 6rpx 0;
  width: 520rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

button {
  margin: 0;
  padding: 0;
  line-height: normal;
  background-color: transparent;
}

.user-item {
  display: flex;
  align-items: center;
  padding: 0 32rpx;
  height: 140rpx;
}

.user-item .avatars {
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  background-color: #f5f5f5;
}

.user-item .infos {
  flex: 1;
  margin: 0 30rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.user-item .titles {
  display: flex;
  align-items: center;
}

.user-item .nickname {
  flex: 1;
  line-height: 50rpx;
  height: 50rpx;
  font-size: 30rpx;
  width: 100%;
  color: #333;
  margin: 0;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.user-item .nickname text {
  line-height: 50rpx;
  height: 50rpx;
}

.user-item .intro {
  height: 44rpx;
  line-height: 44rpx;
  width: 100%;
  font-size: 24rpx;
  color: #949494;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin: 0;
}

.hit_search {
  padding: 140rpx 40rpx 0;
}

.hit_search2 {
  padding: 40rpx 40rpx 0;
}

.stitle {
  font-size: 28rpx;
  color: #000;
  letter-spacing: 1.2rpx;
  margin-bottom: 20rpx;
}

.keywords {
  position: relative;
  color: #949494;
  display: inline-block;
  background: #f5f5f5;
  border-radius: 100rpx;
  padding: 14rpx 33rpx;
  margin: 20rpx 20rpx 0 0;
  max-width: 260rpx;
  /* overflow: hidden; */
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 22rpx;
  animation: fadeIn 0.6s ease;
}

.hit_words {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-start;
  max-height: 300rpx;
}

.stitle-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.stitle-box .stitle-img {
  width: 38rpx;
  height: 38rpx;
}

.stitle-delbox {
  font-size: 24rpx;
  color: #949494;
  display: flex;
  align-items: center;

}

.stitle-delbox .shu {
  height: 20rpx;
  width: 3rpx;
  background: #949494;
  margin: 20rpx;
}

.audio-img {
  position: absolute;
  z-index: 99;
  width: 30rpx;
  height: 30rpx;
  top: -10rpx;
  right: -10rpx;
}