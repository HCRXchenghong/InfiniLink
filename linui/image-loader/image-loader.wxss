/* pages/component/imagePrevLoad/imagePrevLoad.wxss */
@keyframes fadeIn {
    0% {
        opacity: 0;
    }

    50% {
        opacity: 0.5;
    }

    100% {
        opacity: 1;
    }
}

.fade_in {
    animation: fadeIn 1s ease;
    width: 100%;
    height: 100%;
    border-radius: 8rpx;
    background: #f5f5f5;
}